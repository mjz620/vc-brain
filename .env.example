# Copy to .env and fill in. .env is gitignored.

# Agent layer — either provider works. At least one is required for live runs;
# neither is needed for `--replay` runs or for the test suite.
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# External evidence retrieval during diligence (market sizing, news).
TAVILY_API_KEY=

# Postgres connection string. Leave unset to use the local SQLite database.
# DATABASE_URL=

# Cache-only mode: a cache miss raises instead of calling out. Useful for demos.
# VC_REPLAY=1

# Cap on adversarial adjudications per diligence run (each is a 3-call debate).
# VC_MAX_ADJUDICATIONS=6
